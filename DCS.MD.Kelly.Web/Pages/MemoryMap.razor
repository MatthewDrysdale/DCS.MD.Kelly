@page "/memory-map"
@inject DataService Data
@inject IJSRuntime JS

<div class="memory-map-page">

    <div class="page-header">
        <h1>Memory Map 🗺️</h1>
        <p>everywhere we've been together</p>
    </div>

    <div class="map-stats">
        <div class="map-stat">
            <span class="map-stat-number">@locations.Count</span>
            <span class="map-stat-label">places</span>
        </div>
        <div class="map-stat">
            <span class="map-stat-number">@locations.Select(l => l.Country).Distinct().Count()</span>
            <span class="map-stat-label">countries</span>
        </div>
    </div>

    <div class="map-wrapper card">
        <div id="memory-map"></div>
    </div>

    <div class="map-locations-list">
        @foreach (var loc in locations)
        {
            <div class="map-location-chip">
                <span>@loc.Emoji</span>
                <span>@loc.Name</span>
            </div>
        }
    </div>

</div>

@code {
    private List<MapLocation> locations = new();
    private bool mapInitialised = false;

    protected override async Task OnInitializedAsync()
    {
        locations = await Data.GetMapLocationsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!mapInitialised && locations.Any())
        {
            mapInitialised = true;
            await JS.InvokeVoidAsync("mapInterop.initMap", locations);
        }
    }
}