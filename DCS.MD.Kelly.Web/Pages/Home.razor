@page "/"
@inject DataService Data
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<div class="home-page">

    <div class="page-header">
        <h1>Welcome back, my love 💛</h1>
        <p class="current-datetime">@currentDate &nbsp;·&nbsp; @currentTime</p>
        <p class="day-fun-fact">Oh, happy @currentDay! Did you know that we've shared <strong>@togetherWeekdays</strong> @currentDayPlural together? Wowwww.</p>
        <p class="rotating-message">@rotatingMessage</p>
    </div>

    @if (onThisDay.Any())
    {
        <div class="section-title">📅 on this day</div>
        <div class="on-this-day-grid">
            @foreach (var entry in onThisDay)
            {
                <div class="on-this-day-card card">
                    <div class="otd-top">
                        <span class="otd-emoji">@entry.Emoji</span>
                        <span class="timeline-category @entry.Category">@entry.Category</span>
                    </div>
                    <div class="otd-year">@entry.ParsedDate.Year — @yearsAgo(entry) ago</div>
                    <div class="otd-title">@entry.Title</div>
                    <p class="otd-description">@entry.Description</p>
                </div>
            }
        </div>
    }

    <div class="section-title">✨ explore your little website</div>

    <div class="bubbles-container">
        <div class="bubble" @onclick='() => Nav.NavigateTo("stats")'>
            <div class="bubble-icon">💛</div>
            <div class="bubble-label">Stats</div>
        </div>
@*         <div class="bubble" @onclick='() => Nav.NavigateTo("timeline")'>
            <div class="bubble-icon">📅</div>
            <div class="bubble-label">Timeline</div>
        </div> *@
        <div class="bubble" @onclick='() => Nav.NavigateTo("memory-map")'>
            <div class="bubble-icon">🗺️</div>
            <div class="bubble-label">Memory Map</div>
        </div>
        <div class="bubble" @onclick='() => Nav.NavigateTo("pets")'>
            <div class="bubble-icon">🐾</div>
            <div class="bubble-label">Pets</div>
        </div>
        <div class="bubble" @onclick='() => Nav.NavigateTo("playlist")'>
            <div class="bubble-icon">🎵</div>
            <div class="bubble-label">Playlist</div>
        </div>
        <div class="bubble" @onclick='() => Nav.NavigateTo("reasons")'>
            <div class="bubble-icon">💛</div>
            <div class="bubble-label">Why I Love You</div>
        </div>
    </div>

</div>

@code {
    #region Variables

    private string currentDay = string.Empty;
    private string currentDayPlural = string.Empty;
    private string currentDate = string.Empty;
    private string currentTime = string.Empty;
    private string rotatingMessage = string.Empty;

    private readonly DateTime togetherDate = new DateTime(2015, 7, 12);

    private int lastMinute = -1;
    private int togetherWeekdays;

    private Timer? timer;
    private List<TimelineEntry> onThisDay = new();

    private readonly string[] messages = new[]
    {
        "My best friend in the whole world.",
        "My favourite human.",
        "Hey bestie!",
        "Love you lots like jelly tots.",
        "I love you more!",
        "My sunshine on a cloudy day.",
        "am.",
        "Marnie says love you mommy!",
        "Jiji says hey.",
        "Phoebe says awoowomwomwoo!",
        "Pretty Face!",
        "My person.",
        "Best Woman in the world ever.",
        "Your beauty is unmatched, my love.",
        "You are the light of my life.",
        "My reason for everything.",
        "Two cheeks of a bum is we.",
        "Snoop is wondering whether you have any snacks."
    };

    #endregion

    protected override void OnInitialized()
    {
        Recalculate();
        timer = new Timer(_ =>
        {
            Recalculate();
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private void Recalculate()
    {
        var now = DateTime.Now;
        var togetherSpan = now - togetherDate;
        togetherWeekdays = (int)(togetherSpan.TotalDays / 7);
        currentDate = now.ToString("dddd, dd MMMM yyyy");
        currentTime = now.ToString("hh:mm:ss tt");
        currentDay = now.DayOfWeek.ToString();
        currentDayPlural = now.DayOfWeek.ToString() + "s";

        if (now.Minute != lastMinute)
        {
            lastMinute = now.Minute;
            var rng = new Random();
            rotatingMessage = messages[rng.Next(messages.Length)];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var all = await Data.GetTimelineAsync();
        var today = DateTime.Now;
        onThisDay = all
            .Where(e => e.ParsedDate.Day == today.Day && e.ParsedDate.Month == today.Month)
            .OrderBy(e => e.ParsedDate)
            .ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("bubblesInterop.init");
        }
    }

    private string yearsAgo(TimelineEntry entry)
    {
        var years = DateTime.Now.Year - entry.ParsedDate.Year;
        return years == 0 ? "this year" : years == 1 ? "1 year" : $"{years} years";
    }

    #region Disposal
    public void Dispose()
    {
        timer?.Dispose();
        JS.InvokeVoidAsync("bubblesInterop.destroy");
    }
    #endregion

}