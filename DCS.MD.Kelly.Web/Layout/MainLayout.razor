@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

<AuthorizedView>
    <div class="app-layout">
        <header class="topbar">
            <div class="topbar-inner">
                <div class="topbar-brand">
                    <span class="app-title">💛 Our Little World</span>
                </div>
                <div class="season-indicator">@seasonEmoji</div>
                <a href="/" class="home-btn">🏠</a>
            </div>
        </header>
        <main class="main-content">
            @Body
        </main>
    </div>
</AuthorizedView>

@code {
    private string seasonEmoji = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var season = await JS.InvokeAsync<string>("themeInterop.applyTheme");
            seasonEmoji = season switch
            {
                "spring" => "🌸",
                "summer" => "☀️",
                "autumn" => "🍂",
                "winter" => "🌙",
                _ => ""
            };
            StateHasChanged();
        }
    }
}